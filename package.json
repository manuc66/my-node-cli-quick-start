{
  "name": "my-node-cli-quick-start",
  "version": "0.0.0-development",
  "description": "Template for a Node CLI project in typescript.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/index.js",
  "scripts": {
    "setup": "node scripts/init-template.mjs",
    "bootstrap": "node scripts/bootstrap.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "mocha",
    "test:watch": "mocha --watch",
    "test:coverage": "c8 --reporter=lcov --reporter=text --exclude=\"test/\" --check-coverage --lines 80 --functions 80 --branches 75 mocha",
    "check": "eslint . && tsc --noEmit && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "eslint . --fix && prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "clean": "rimraf dist coverage .eslintcache",
    "build": "pnpm -s clean && tsc -p . && node scripts/validate-build.mjs",
    "ci": "pnpm check && pnpm test:coverage && pnpm build",
    "prepare": "husky install || true"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/chai": "^5.2.3",
    "@types/config": "^3.3.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.1",
    "c8": "^10.1.3",
    "chai": "^6.2.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "mocha": "^11.7.4",
    "nock": "^14.0.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "config": "^4.1.1",
    "dotenv": "^16.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^8.1.0",
    "zod": "^4.1.12"
  },
  "packageManager": "pnpm@9.0.0"
}
